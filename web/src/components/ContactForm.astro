---
// Kontaktformular -> /kontakt.php (Mail via one.com-SMTP an info@creative-cinema.net), zweisprachig.
// Spamschutz: Honeypot + Zeitfalle + Pflicht-Häkchen + Rechen-Bot-Test (challenge.php).
interface Props { lang?: 'de' | 'en' }
const { lang = 'de' } = Astro.props;
const en = lang === 'en';
const t = en
  ? { name: 'Name', email: 'Email', phone: 'Phone', subject: 'Preferred date / subject', message: 'Your message',
      captcha: 'Anti-spam: what is', privacyA: 'I have read the', privacyB: 'privacy policy', privacyC: 'and consent to my data being processed to handle my enquiry.',
      submit: 'Send enquiry', note: '* Required · reply within 24 hours', policyHref: '/en/privacy/',
      noscript: 'Please enable JavaScript to use the form – or email', hp: 'Please leave blank' }
  : { name: 'Name', email: 'E-Mail', phone: 'Telefon', subject: 'Wunschtermin / Betreff', message: 'Ihre Nachricht',
      captcha: 'Bot-Schutz: Wie viel ist', privacyA: 'Ich habe die', privacyB: 'Datenschutzerklärung', privacyC: 'gelesen und stimme der Verarbeitung meiner Angaben zur Bearbeitung meiner Anfrage zu.',
      submit: 'Anfrage senden', note: '* Pflichtfelder · Antwort in 24 Stunden', policyHref: '/datenschutz/',
      noscript: 'Für das Formular bitte JavaScript aktivieren – oder schreiben Sie an', hp: 'Bitte frei lassen' };
---
<form class="cform" id="cform" method="post" action="/kontakt.php" data-lang={lang} novalidate>
  <div class="cform-status" id="cform-status" role="status" aria-live="polite" hidden></div>

  <div class="cform-grid">
    <label class="cf-field"><span class="cf-lab">{t.name} <em>*</em></span><input type="text" name="name" required autocomplete="name" /></label>
    <label class="cf-field"><span class="cf-lab">{t.email} <em>*</em></span><input type="email" name="email" required autocomplete="email" /></label>
    <label class="cf-field"><span class="cf-lab">{t.phone}</span><input type="tel" name="phone" autocomplete="tel" /></label>
    <label class="cf-field"><span class="cf-lab">{t.subject}</span><input type="text" name="subject" /></label>
  </div>

  <label class="cf-field"><span class="cf-lab">{t.message} <em>*</em></span><textarea name="message" rows="5" required></textarea></label>

  <label class="cf-field cf-captcha">
    <span class="cf-lab">{t.captcha} <strong id="cf-q">…</strong>? <em>*</em></span>
    <input type="text" name="captcha" inputmode="numeric" autocomplete="off" required aria-label={t.captcha} />
  </label>
  <input type="hidden" name="captcha_token" id="cf-token" value="" />

  <label class="cf-check">
    <input type="checkbox" name="privacy" required />
    <span>{t.privacyA} <a href={t.policyHref} target="_blank" rel="noopener">{t.privacyB}</a> {t.privacyC} <em>*</em></span>
  </label>

  <div class="cf-hp" aria-hidden="true"><label>{t.hp}<input type="text" name="website" tabindex="-1" autocomplete="off" /></label></div>
  <input type="hidden" name="t" value="" />

  <div class="cf-actions">
    <button type="submit" class="btn btn-primary magnetic">{t.submit} <span class="arrow">→</span></button>
    <span class="cf-note">{t.note}</span>
  </div>
  <noscript><p class="cf-note" style="margin-top:12px">{t.noscript} <a href="mailto:info@creative-cinema.net">info@creative-cinema.net</a>.</p></noscript>
</form>

<script is:inline>
(function () {
  var f = document.getElementById('cform'); if (!f) return;
  var en = f.getAttribute('data-lang') === 'en';
  var MSG = en
    ? { ok: "Thank you! We'll get back to you within 24 hours.", err: 'Please check your entries (incl. the anti-spam question) – or email info@creative-cinema.net.', fail: 'Sending failed. Please email info@creative-cinema.net.' }
    : { ok: 'Danke! Wir melden uns innerhalb von 24 Stunden.', err: 'Bitte prüfen Sie Ihre Eingaben (inkl. Rechenaufgabe) – oder schreiben Sie an info@creative-cinema.net.', fail: 'Senden fehlgeschlagen. Bitte schreiben Sie an info@creative-cinema.net.' };
  var status = document.getElementById('cform-status');
  var tfield = f.querySelector('input[name=t]'); if (tfield) tfield.value = String(Date.now());
  var qEl = document.getElementById('cf-q'); var tokEl = document.getElementById('cf-token');
  function loadChallenge() {
    if (qEl) qEl.textContent = '…';
    fetch('/challenge.php', { headers: { 'X-Requested-With': 'fetch' } })
      .then(function (r) { return r.json(); })
      .then(function (d) { if (d && d.q) { qEl.textContent = d.q; tokEl.value = d.token || ''; } else { qEl.textContent = en ? '(reload page)' : '(Seite neu laden)'; } })
      .catch(function () { qEl.textContent = en ? '(reload page)' : '(Seite neu laden)'; });
  }
  loadChallenge();
  function show(ok, msg) { status.hidden = false; status.textContent = msg; status.className = 'cform-status ' + (ok ? 'ok' : 'err'); status.scrollIntoView({ behavior: 'smooth', block: 'center' }); }
  try {
    var p = new URLSearchParams(location.search);
    if (p.get('sent') === 'ok') show(true, MSG.ok);
    else if (p.get('sent') === 'err') show(false, MSG.err);
  } catch (e) {}
  f.addEventListener('submit', function (e) {
    e.preventDefault();
    if (!f.checkValidity()) { f.reportValidity(); return; }
    var btn = f.querySelector('button[type=submit]'); btn.disabled = true;
    fetch('/kontakt.php', { method: 'POST', headers: { 'X-Requested-With': 'fetch' }, body: new FormData(f) })
      .then(function (r) { return r.json(); })
      .then(function (d) { show(!!d.ok, d.ok ? MSG.ok : MSG.err); btn.disabled = false; if (tfield) tfield.value = String(Date.now()); if (d.ok) { f.reset(); } loadChallenge(); })
      .catch(function () { show(false, MSG.fail); btn.disabled = false; loadChallenge(); });
  });
})();
</script>

<style>
  .cform { margin-top: 8px; }
  .cform-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .cf-field { display: block; margin-bottom: 16px; }
  .cf-lab { display: block; font-family: var(--font-body); font-weight: 600; font-size: .9rem; color: var(--bone); margin-bottom: 7px; }
  .cf-lab em { color: var(--led); font-style: normal; }
  .cf-captcha .cf-lab strong { color: var(--led); font-family: var(--font-head); }
  .cform input[type=text], .cform input[type=email], .cform input[type=tel], .cform textarea {
    width: 100%; background: var(--panel-2, #1D2026); color: var(--bone, #F2EFE8);
    border: 1px solid var(--line, #2A2D34); border-radius: var(--radius, 14px);
    padding: 12px 14px; font: inherit; font-size: .98rem; transition: border-color .2s, box-shadow .2s;
  }
  .cf-captcha { max-width: 260px; }
  .cform textarea { resize: vertical; min-height: 120px; }
  .cform input:focus, .cform textarea:focus { outline: none; border-color: var(--ci-rot, #C23336); box-shadow: 0 0 0 3px rgba(194,51,54,.18); }
  .cf-check { display: flex; gap: 11px; align-items: flex-start; margin: 6px 0 22px; color: var(--muted, #9CA0A8); font-size: .88rem; line-height: 1.5; cursor: pointer; }
  .cf-check input { margin-top: 3px; width: 17px; height: 17px; flex: none; accent-color: var(--ci-rot, #C23336); }
  .cf-check a { color: var(--led, #D9494C); }
  .cf-check em { color: var(--led); font-style: normal; }
  .cf-actions { display: flex; align-items: center; gap: 18px; flex-wrap: wrap; }
  .cf-note { color: var(--muted); font-size: .82rem; }
  .cf-hp { position: absolute; left: -9999px; width: 1px; height: 1px; overflow: hidden; }
  .cform-status { border-radius: var(--radius, 14px); padding: 13px 16px; margin-bottom: 18px; font-size: .92rem; border: 1px solid var(--line); }
  .cform-status.ok { background: rgba(60,160,90,.12); border-color: rgba(60,160,90,.5); color: #d7f5e1; }
  .cform-status.err { background: rgba(194,51,54,.12); border-color: rgba(194,51,54,.5); color: #f7d7d8; }
  @media (max-width: 560px) { .cform-grid { grid-template-columns: 1fr; } }
</style>
