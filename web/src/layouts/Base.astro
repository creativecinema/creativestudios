---
// Basis-Layout: <head>, per-Seite SEO (Canonical, hreflang, JSON-LD, OpenGraph),
// globale Chrome (Filmkorn, Letterbox-Intro, Scroll-Progress) und das Design-System.
import CookieConsent from '../components/CookieConsent.astro';
export interface Props {
  lang: 'de' | 'en';
  title: string;
  description: string;
  path?: string;          // z. B. "" (Start) oder "studio/led-studio-mieten/"
  hasEN?: boolean;        // existiert eine EN-Variante dieser Seite?
  jsonld?: object[];      // Schema.org-Objekte für den <head>
  ogImage?: string;       // absolute URL; Default unten
  robots?: string;        // z. B. 'noindex, follow' für Rechtstexte/404
  noHreflang?: boolean;   // EN-only-Seiten ohne DE-Pendant (kein hreflang-Alternate)
}
const {
  lang, title, description, path = '', hasEN = true, jsonld = [],
  ogImage, robots = 'index, follow', noHreflang = false,
} = Astro.props;

const base = 'https://creative-studios.tv/';
const canonical = lang === 'de' ? base + path : base + 'en/' + path;
const altDe = base + path;
const altEn = base + 'en/' + path;
const og = ogImage || base + 'og-cover.jpg';
const ogAlt = lang === 'de'
  ? 'CreativeCinema – Filmproduktion & Virtual-Production-Studio in Erlangen/Nürnberg'
  : 'CreativeCinema – video & virtual production studio in Germany';
---
<!doctype html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <script is:inline>document.documentElement.className+=' js';addEventListener('DOMContentLoaded',function(){document.body.classList.add('loaded')});setTimeout(function(){document.body&&document.body.classList.add('loaded')},1600);</script>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content={robots} />
  <meta name="google-site-verification" content="Yw7e9x4SyxSiKK7ImpzOBVD95PDhr23O5ObgEuMDLjs" />
  <link rel="canonical" href={canonical} />
  {!noHreflang && <link rel="alternate" hreflang="de" href={altDe} />}
  {!noHreflang && hasEN && <link rel="alternate" hreflang="en" href={altEn} />}
  {!noHreflang && <link rel="alternate" hreflang="x-default" href={altDe} />}
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="CreativeCinema" />
  <meta property="og:url" content={canonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:locale" content={lang === 'de' ? 'de_DE' : 'en_US'} />
  {hasEN && <meta property="og:locale:alternate" content={lang === 'de' ? 'en_US' : 'de_DE'} />}
  <meta property="og:image" content={og} />
  <meta property="og:image:type" content="image/jpeg" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content={ogAlt} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={og} />
  <meta name="theme-color" content="#101114" />
  <link rel="icon" href="/assets/cc-logo-rocket.svg" type="image/svg+xml" />
  <link rel="preload" href="/fonts/poppins-800-latin.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/source-sans-3-400-latin.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="stylesheet" href="/styles/fonts.css" />
  <link rel="stylesheet" href="/styles/cc.css" />
  {jsonld.map((obj) => <script type="application/ld+json" set:html={JSON.stringify(obj)} />)}
  <slot name="head" />
</head>
<body>
  <div class="grain" aria-hidden="true"></div>
  <div class="cinebars" aria-hidden="true"><i class="top"></i><i class="bot"></i></div>
  <div class="progress" aria-hidden="true"></div>
  <slot />
  <CookieConsent lang={lang} />
  <script is:inline src="/scripts/cc.js"></script>
</body>
</html>
