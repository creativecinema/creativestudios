---
import Base from '../../layouts/Base.astro';
import Home from '../../components/Home.astro';
import { home } from '../../data/home';
import { mergeHome } from '../../lib/mergeHome.js';
import { useStoryblokApi } from '@storyblok/astro';

// Gleiche Story "home", aber mit aufgelösten EN-Übersetzungen (language: 'en').
let t = home.en;
try {
  const api = useStoryblokApi();
  const version = import.meta.env.DEV ? 'draft' : 'published'; // Live: nur Publiziertes
  const { data } = await api.get('cdn/stories/home', { version, language: 'en' });
  if (data?.story?.content) t = mergeHome(home.en, data.story.content);
} catch (e) {
  console.warn('[Storyblok] Fallback auf home.ts (EN):', e?.message || e);
}

// Rechtliche Footer-Links immer auf die echten Seiten zeigen (unabhängig von Storyblok-Altdaten)
for (const l of t.footer.links) {
  if (/impressum|imprint/i.test(l.label)) l.href = '/impressum/';
  if (/datenschutz|privacy/i.test(l.label)) l.href = '/datenschutz/';
}

// Keep contact NAP consistent: unify e-mail + ensure phone number
t.contact.nap = t.contact.nap.map((l) => l.replace(/as@creative-cinema\.net/g, 'info@creative-cinema.net'));
if (!t.contact.nap.some((l) => /174/.test(l))) {
  const i = t.contact.nap.findIndex((l) => l.includes('@'));
  if (i >= 0) t.contact.nap.splice(i, 0, 'Phone +49 174 8484842'); else t.contact.nap.push('Phone +49 174 8484842');
}

const jsonld = [
  {
    '@context': 'https://schema.org', '@type': 'Organization', '@id': 'https://creative-studios.tv/#org',
    name: 'CreativeCinema GmbH', url: 'https://creative-studios.tv/',
    logo: 'https://creative-studios.tv/assets/cc-logo-white.svg',
    image: 'https://creative-studios.tv/og-cover.jpg', email: 'info@creative-cinema.net', telephone: '+49 174 8484842',
    description: t.meta.description,
    address: { '@type': 'PostalAddress', streetAddress: 'Gundstraße 13a', postalCode: '91056', addressLocality: 'Erlangen', addressRegion: 'Bavaria', addressCountry: 'DE' },
  },
  {
    '@context': 'https://schema.org', '@type': 'WebSite', '@id': 'https://creative-studios.tv/#website',
    url: 'https://creative-studios.tv/', name: 'CreativeCinema', inLanguage: ['de', 'en'],
    publisher: { '@id': 'https://creative-studios.tv/#org' },
  },
  {
    '@context': 'https://schema.org', '@type': ['LocalBusiness', 'ProfessionalService'], '@id': 'https://creative-studios.tv/#business',
    name: 'CreativeCinema GmbH', description: t.meta.description, slogan: 'Direct. Innovative. Production-proof.',
    image: 'https://creative-studios.tv/og-cover.jpg', url: 'https://creative-studios.tv/', email: 'info@creative-cinema.net', telephone: '+49 174 8484842',
    priceRange: '€€', knowsLanguage: ['de', 'en'],
    address: { '@type': 'PostalAddress', streetAddress: 'Gundstraße 13a', postalCode: '91056', addressLocality: 'Erlangen', addressRegion: 'Bavaria', addressCountry: 'DE' },
    areaServed: ['Germany', 'Europe', 'Erlangen', 'Nuremberg', 'Bavaria'],
    makesOffer: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'LED studio / virtual production stage rental' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Video & virtual production' } },
    ],
  },
];
---
<Base lang="en" title={t.meta.title} description={t.meta.description} jsonld={jsonld}>
  <Home lang="en" t={t} />
</Base>
