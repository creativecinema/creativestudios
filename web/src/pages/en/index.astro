---
import Base from '../../layouts/Base.astro';
import Home from '../../components/Home.astro';
import { home } from '../../data/home';
import { mergeHome } from '../../lib/mergeHome.js';
import { useStoryblokApi } from '@storyblok/astro';

// Gleiche Story "home", aber mit aufgelösten EN-Übersetzungen (language: 'en').
let t = home.en;
try {
  const api = useStoryblokApi();
  const version = import.meta.env.DEV ? 'draft' : 'published'; // Live: nur Publiziertes
  const { data } = await api.get('cdn/stories/home', { version, language: 'en' });
  if (data?.story?.content) t = mergeHome(home.en, data.story.content);
} catch (e) {
  console.warn('[Storyblok] Fallback auf home.ts (EN):', e?.message || e);
}

// Rechtliche Footer-Links immer auf die echten Seiten zeigen (unabhängig von Storyblok-Altdaten)
for (const l of t.footer.links) {
  if (/impressum|imprint/i.test(l.label)) l.href = '/impressum/';
  if (/datenschutz|privacy/i.test(l.label)) l.href = '/datenschutz/';
}

const jsonld = [{
  '@context': 'https://schema.org', '@type': 'LocalBusiness', name: 'CreativeCinema GmbH',
  description: t.meta.description, slogan: 'Direct. Innovative. Production-proof.',
  address: { '@type': 'PostalAddress', streetAddress: 'Gundstraße 13a', postalCode: '91056', addressLocality: 'Erlangen', addressCountry: 'DE' },
  areaServed: ['Germany', 'Europe', 'Erlangen', 'Nuremberg'], url: 'https://creative-studios.tv/en/', email: 'as@creative-cinema.net',
  makesOffer: [
    { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'LED Studio / Virtual Production Stage rental' } },
    { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Virtual Production / XR film production' } },
  ],
}];
---
<Base lang="en" title={t.meta.title} description={t.meta.description} jsonld={jsonld}>
  <Home lang="en" t={t} />
</Base>
