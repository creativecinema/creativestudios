---
import Base from '../layouts/Base.astro';
import Home from '../components/Home.astro';
import { home } from '../data/home';
import { mergeHome } from '../lib/mergeHome.js';
import { useStoryblokApi } from '@storyblok/astro';

let t = home.de;
try {
  const api = useStoryblokApi();
  const version = import.meta.env.DEV ? 'draft' : 'published'; // Live: nur Publiziertes
  const { data } = await api.get('cdn/stories/home', { version });
  if (data?.story?.content) t = mergeHome(home.de, data.story.content);
} catch (e) {
  console.warn('[Storyblok] Fallback auf home.ts (DE):', e?.message || e);
}

const jsonld = [{
  '@context': 'https://schema.org', '@type': 'LocalBusiness', name: 'CreativeCinema GmbH',
  description: t.meta.description, slogan: 'Direkt. Innovativ. Produktionssicher.',
  address: { '@type': 'PostalAddress', streetAddress: 'Gundstraße 13a', postalCode: '91056', addressLocality: 'Erlangen', addressCountry: 'DE' },
  areaServed: ['Erlangen', 'Nürnberg', 'Fürth', 'Bayern'], url: 'https://creative-studios.tv/', email: 'as@creative-cinema.net',
  makesOffer: [
    { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'LED-Studio Vermietung' } },
    { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Virtual Production / XR-Filmproduktion' } },
  ],
}];
---
<Base lang="de" title={t.meta.title} description={t.meta.description} jsonld={jsonld}>
  <Home lang="de" t={t} />
</Base>
